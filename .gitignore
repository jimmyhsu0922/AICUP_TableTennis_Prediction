# =========================================================================
# Python & Jupyter 快取
# =========================================================================
__pycache__/
*.pyc
*.pyo
*.pyd
.ipynb_checkpoints/
.pytest_cache/

# =========================================================================
# 虛擬環境 (Virtual Environments)
# =========================================================================
venv/
.venv/
env/
ENV/

# =========================================================================
# 📊 競賽大型資料與權重 (避免超過 GitHub 100MB 限制)
# =========================================================================
# 忽略所有資料集檔案（只留下目錄結構，不傳大檔）
data/*.csv
data/*.zip

# 忽略所有模型訓練權重檔
checkpoints/*.pt
checkpoints/*.pth
checkpoints/*.pkl
checkpoints/*.h5

# =========================================================================
# 編輯器暫存檔 (IDE Settings)
# =========================================================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# =========================================================================
# 作業系統產生的雜物
# =========================================================================
.DS_Store
Thumbs.db
